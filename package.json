{
  "name": "steammini",
  "version": "1.0.1",
  "description": "",
  "main": "electron/main.js",
  "scripts": {
    "build:csharp": "npm run build:sam && npm run build:cards",
    "build:sam": "dotnet build csharp/SAMBackend -c Release -o resources/",
    "build:cards": "dotnet build csharp/CardDropsBackend -c Release -o resources/",
    "dev": "npm run build:csharp && concurrently \"vite\" \"wait-on http://localhost:3000 && electron .\"",
    "build": "npm run build:csharp && vite build && electron-builder",
    "preview": "vite preview",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:cover": "vitest run --coverage",
    "test:watch": "vitest --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "concurrently": "^9.2.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-mock-ipc": "^0.3.14",
    "jsdom": "^28.1.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "crypto-js": "^4.2.0",
    "electron-log": "^5.1.2",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.1.7",
    "steamcommunity": "^3.49.0",
    "steamworks.js": "^0.4.0",
    "vdf-parser": "^1.2.1",
    "ws": "^8.19.0"
  }
}
